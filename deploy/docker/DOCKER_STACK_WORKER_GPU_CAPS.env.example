# 必改项 1：代码目录（宿主机绝对路径）
BOLTZ_HOST_ROOT=/data/V-Bio
RESULTS_BASE_DIR=/data/boltz_central_results

# 必改项 2：中央连接
BOLTZ_API_TOKEN=change-me
REDIS_URL=redis://<CENTRAL_HOST_OR_IP>:6379/0
CENTRAL_API_URL=http://<CENTRAL_HOST_OR_IP>:5000

# 必改项 3：MSA 服务（boltz2/alphafold3/protenix/boltz2score 需要）
MSA_SERVER_URL=http://<MSA_HOST_OR_IP>:8080
MSA_SERVER_MODE=colabfold
# MSA 单序列轮询超时（秒）；MSA 较慢时可调大到 1800/3600
MSA_SERVER_TIMEOUT_SECONDS=1800

# Boltz runtime（boltz2 / boltz2score / affinity 共用）
BOLTZ2_DOCKER_IMAGE=vbio-boltz2-runtime
BOLTZ2_DOCKER_EXTRA_ARGS=
BOLTZ2_DOCKER_SHM_SIZE=16g
BOLTZ2_HOST_CACHE_DIR=/data/boltz_cache
BOLTZ2_CONTAINER_CACHE_DIR=/root/.boltz
# 可选：下载重试与镜像 URL 覆盖（国内网络建议设置）
BOLTZ_DOWNLOAD_RETRIES=3
BOLTZ_CCD_URL=
BOLTZ1_MODEL_URL=
BOLTZ2_MOLS_URL=
BOLTZ2_MODEL_URL=
BOLTZ2_AFFINITY_MODEL_URL=

# AlphaFold3（启用 alphafold3 profile 时必填）
ALPHAFOLD3_DOCKER_IMAGE=cford38/alphafold3
ALPHAFOLD3_MODEL_DIR=/data/alphafold3/models
ALPHAFOLD3_DATABASE_DIR=/data/alphafold3/databases
ALPHAFOLD3_DOCKER_EXTRA_ARGS=

# Protenix（启用 protenix profile 时必填）
PROTENIX_DOCKER_IMAGE=ai4s-share-public-cn-beijing.cr.volces.com/release/protenix:1.0.0.4
PROTENIX_MODEL_DIR=/data/protenix/model
PROTENIX_MODEL_NAME=protenix_base_20250630_v1.0.0
PROTENIX_SOURCE_DIR=/data/protenix/source
PROTENIX_COMMON_CACHE_DIR=/data/protenix/common_cache
PROTENIX_CONTAINER_APP_DIR=/app
PROTENIX_CONTAINER_MODEL_DIR=/workspace/model
PROTENIX_CONTAINER_CHECKPOINT_PATH=

# PocketXMol（启用 pocketxmol profile 时可选）
POCKETXMOL_DOCKER_IMAGE=pocketxmol:cu128
POCKETXMOL_ROOT_DIR=./capabilities/pocketxmol
POCKETXMOL_CONFIG_MODEL=configs/sample/pxm.yml
POCKETXMOL_DEVICE=cuda:0
POCKETXMOL_BATCH_SIZE=50

# 宿主机挂载覆盖（可选）
PROTENIX_SOURCE_DIR_HOST=/data/protenix
ALPHAFOLD3_ROOT_HOST=/data/alphafold3

# 每个 capability worker 的并发上限（默认 -1：自动使用全部可见 GPU）
# 可按机器资源显式限流，例如设为 1/2。
MAX_CONCURRENT_TASKS_BOLTZ2=-1
MAX_CONCURRENT_TASKS_BOLTZ2SCORE=-1
MAX_CONCURRENT_TASKS_AFFINITY=-1
MAX_CONCURRENT_TASKS_ALPHAFOLD3=-1
MAX_CONCURRENT_TASKS_PROTENIX=-1
MAX_CONCURRENT_TASKS_POCKETXMOL=-1

# 默认留空即可：多个 capability 可共享/争抢同一张 GPU，以提高总体利用率。
# 如需做资源隔离或稳定性调优，再显式划分 GPU（可选）：
# 示例：GPU_DEVICE_IDS_BOLTZ2=0,1
#      GPU_DEVICE_IDS_ALPHAFOLD3=2
#      GPU_DEVICE_IDS_PROTENIX=3
GPU_DEVICE_IDS_BOLTZ2=
GPU_DEVICE_IDS_BOLTZ2SCORE=
GPU_DEVICE_IDS_AFFINITY=
GPU_DEVICE_IDS_ALPHAFOLD3=
GPU_DEVICE_IDS_PROTENIX=
GPU_DEVICE_IDS_POCKETXMOL=
