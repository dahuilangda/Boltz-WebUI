# 必改项 1：代码目录（宿主机绝对路径）
BOLTZ_HOST_ROOT=/data/V-Bio

# 可选：端口
API_HOST_PORT=5000
REDIS_HOST_PORT=6379

# 必改项 2：统一令牌（与 worker/frontend 一致）
BOLTZ_API_TOKEN=change-me
# 固定：中央栈内 redis 服务名
REDIS_URL=redis://redis:6379/0
# 固定：中央 API 对外地址（中央容器内部）
CENTRAL_API_URL=http://127.0.0.1:5000

# Lead-Opt / MMP 管理接口连接的 PostgreSQL
LEAD_OPT_MMP_DB_URL=postgresql://leadopt:leadopt@<DB_HOST>:54330/leadopt_mmp
LEAD_OPT_MMP_DB_SCHEMA=chembl_cyp3a4_herg

# 必改项 3：ColabFold MSA 服务（可独立部署）
MSA_SERVER_URL=http://<MSA_HOST_OR_IP>:8080
MSA_SERVER_MODE=colabfold
MSA_SERVER_TIMEOUT_SECONDS=1800
COLABFOLD_JOBS_DIR=/data/colabfold/jobs

# 可选：结果目录
RESULTS_BASE_DIR=/data/boltz_central_results
