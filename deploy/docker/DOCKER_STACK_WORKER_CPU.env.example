# 必改项 1：代码目录（宿主机绝对路径）
BOLTZ_HOST_ROOT=/data/V-Bio
RESULTS_BASE_DIR=/data/boltz_central_results

# 必改项 2：中央连接
BOLTZ_API_TOKEN=change-me
REDIS_URL=redis://<CENTRAL_HOST_OR_IP>:6379/0
CENTRAL_API_URL=http://<CENTRAL_HOST_OR_IP>:5000

# 必改项 3：CPU 能力声明
# 例如仅 lead-opt: lead_opt
# 如需承接多肽父编排任务: lead_opt,peptide_design
CPU_WORKER_CAPABILITIES=lead_opt,peptide_design

# 并发：0=自动使用全部CPU核心
CPU_MAX_CONCURRENT_TASKS=0

# 必改项 4：Lead-Opt / MMP 数据库
LEAD_OPT_MMP_DB_URL=postgresql://leadopt:leadopt@<DB_HOST>:54330/leadopt_mmp
LEAD_OPT_MMP_DB_SCHEMA=chembl_cyp3a4_herg
