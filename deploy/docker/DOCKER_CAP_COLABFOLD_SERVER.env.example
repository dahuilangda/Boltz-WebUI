COLABFOLD_SERVER_IMAGE=vbio-colabfold-server
COLABFOLD_SERVER_CONTAINER_NAME=vbio-colabfold-server
COLABFOLD_SERVER_PORT=8080
COLABFOLD_DOCKER_GPUS=all

COLABFOLD_UID=1000
COLABFOLD_GID=1000

COLABFOLD_DB_DIR=/data/colabfold/databases
COLABFOLD_JOBS_DIR=/data/colabfold/jobs
COLABFOLD_CONFIG_PATH=/data/V-Bio/capabilities/colabfold_server/config.json

COLABFOLD_MMSEQS_LOAD_MODE=2
# 1=启用 MMseqs GPU 参数（单一 MMseqs 二进制）
COLABFOLD_ENABLE_GPU=0
COLABFOLD_SHM_SIZE=64gb
COLABFOLD_MEM_LIMIT=96g

# 可选: 走代理构建/运行
APT_MIRROR=
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
http_proxy=
https_proxy=
no_proxy=

# 可选: Go 下载镜像（国内建议设置）
# 示例: https://mirrors.aliyun.com/golang
GO_DOWNLOAD_URL=
# Go modules 下载（默认不走 proxy.golang.org）
GO_MODULE_PROXY=https://goproxy.cn,direct
GO_SUMDB=off

# 可选: MMseqs 二进制下载地址（完整 URL）
MMSEQS_DOWNLOAD_URL=https://mmseqs.com/latest/mmseqs-linux-gpu.tar.gz

# 可选: 覆盖 PDB 同步参数
PDB_SERVER=rsync.wwpdb.org::ftp
PDB_PORT=33444
PDB_AWS_DOWNLOAD=
PDB_AWS_SNAPSHOT=20240101
